# ───────── Pollería Entre Ríos — variables de entorno ─────────
# Copiá este archivo a ".env" y completá los valores.

# Base de datos PostgreSQL (Prisma).
# En desarrollo local podés dejarlo vacío: la app funciona con datos de ejemplo.
DATABASE_URL="postgresql://polleria:polleria@localhost:5432/polleria?schema=public"

# API key que tu bot de n8n debe enviar en cada request:
#   Authorization: Bearer <API_KEY>
# Generá una larga y aleatoria, por ejemplo: openssl rand -hex 32
# Si se deja vacío, la API queda ABIERTA (solo para desarrollo).
API_KEY="cambia-esta-clave-por-una-aleatoria-y-larga"

# ───────── Login de clientes/admin (OTP por WhatsApp) ─────────

# Clave para firmar las cookies de sesión. OBLIGATORIA en producción (mín. 16 chars).
# Generala con: openssl rand -hex 32
SESSION_SECRET="cambia-esta-clave-de-sesion-por-una-aleatoria-y-larga"

# Webhook de n8n que envía el código OTP por WhatsApp.
# Recibe un POST { phone, code, message }. Si se deja vacío, en desarrollo el
# código se imprime por consola (no se envía nada). En producción es obligatorio.
OTP_WHATSAPP_WEBHOOK_URL=""

# (Opcional) Si lo definís, la web manda "Authorization: Bearer <valor>" al webhook
# para que n8n valide que la petición viene de la web.
OTP_WEBHOOK_SECRET=""

# ───────── Panel /admin (usuario y contraseña únicos) ─────────

# Credenciales del panel de administración (/admin/login).
# En desarrollo, si se dejan vacías, valen admin/admin.
# ADMIN_PASSWORD es OBLIGATORIA en producción.
ADMIN_USER="admin"
ADMIN_PASSWORD="admin123"

# Teléfonos con acceso al panel /admin, separados por coma (en cualquier formato:
# se normalizan a solo dígitos). Quien inicie sesión con uno de estos números
# queda como administrador.
ADMIN_PHONES="+54 9 11 5555 5555"

# ───────── Solo para docker-compose ─────────
POSTGRES_USER=polleria
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=polleria
WEB_PORT=3000
